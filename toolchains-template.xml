<?xml version="1.0" encoding="UTF-8"?>
<!--
    Maven toolchains configuration for GraalVM 26 EA
  Copy this file to ~/.m2/toolchains.xml and update the jdkHome path.
-->
<toolchains xmlns="http://maven.apache.org/TOOLCHAINS/1.1.0"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://maven.apache.org/TOOLCHAINS/1.1.0 http://maven.apache.org/xsd/toolchains-1.1.0.xsd">
    <toolchain>
        <type>jdk</type>
        <provides>
            <version>26</version>
            <vendor>graalvm</vendor>
        </provides>
        <configuration>
            <!-- Update this path to your GraalVM installation -->
            <jdkHome>/path/to/graalvm-jdk-26.ea.13</jdkHome>
        </configuration>
    </toolchain>
</toolchains>
